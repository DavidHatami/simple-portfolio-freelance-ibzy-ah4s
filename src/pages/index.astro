---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-gray-50 to-white py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 tracking-tight">
        Illustrations that tell your story
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto">
        I'm June Kato, a freelance illustrator who creates vibrant, character-driven artwork for books, brands, and editorial projects.
      </p>
      <div class="mt-10">
        <a
          href="#work"
          class="inline-block bg-gray-900 text-white px-8 py-4 rounded-lg text-base font-medium hover:bg-gray-800 transition-colors"
        >
          See my work
        </a>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Hand-crafted style</h3>
          <p class="text-gray-600">
            Every piece starts with pencil sketches before going digital. You get artwork with warmth and personality, not generic stock vibes.
          </p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Clear communication</h3>
          <p class="text-gray-600">
            I keep you in the loop at every stage. Sketches, revisions, final files—no surprises, just smooth collaboration.
          </p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">On-time delivery</h3>
          <p class="text-gray-600">
            Deadlines matter. I plan projects carefully so your artwork arrives when you need it, ready to use.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Section Placeholder -->
  <section id="work" class="py-16 sm:py-24 bg-gray-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Recent work</h2>
      <p class="text-center text-gray-600">Portfolio coming soon.</p>
    </div>
  </section>

  <!-- About Section Placeholder -->
  <section id="about" class="py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">About me</h2>
      <p class="text-center text-gray-600">Bio coming soon.</p>
    </div>
  </section>

  <!-- Hire Me CTA Section -->
  <section id="hire" class="py-16 sm:py-24 bg-gray-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Let's make something together
      </h2>
      <p class="text-gray-300 text-lg mb-8 max-w-2xl mx-auto">
        Got a project in mind? I'd love to hear about it. Whether it's a book cover, editorial illustration, or something completely different—drop me a line.
      </p>
      <a
        href="mailto:hello@junekato.com"
        class="inline-block bg-white text-gray-900 px-8 py-4 rounded-lg text-base font-medium hover:bg-gray-100 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>
</Base>
